# 部署敏感配置模板。用法：
#   cp deploy/deploy.env.example deploy/deploy.env  并填入真实值
# deploy.env 已在 .gitignore 忽略，deploy.sh 会自动读取并同步到服务器。
# 本模板只放占位符，切勿填入真实密钥。

# ── SSH 连接 ──
SERVER_IP=<your.server.ip>
SERVER_USER=ubuntu
SSH_PASS=<your_ssh_password>
# 或改用密钥（设了 SSH_KEY 可不填 SSH_PASS）：
# SSH_KEY=/path/to/your/private_key

# ── docker compose 插值变量 ──
# 主应用↔生活教练免密跳转签名密钥（生成：openssl rand -hex 32）
COACH_SSO_SECRET=<run: openssl rand -hex 32>
# 用户浏览器加载教练 iframe 的公网地址
LIFE_COACH_URL=http://<your.server.ip>:8503
# 「← 返回 ABA 助手」跳回的主应用公网地址
ABA_APP_URL=http://<your.server.ip>:8501
# 容器内健康检查地址（用 compose 服务名，一般不用改）
COACH_HEALTH_URL=http://life-coach:8503/_stcore/health
