# ====================================
# ABA智能助手 - 环境变量配置模板
# ====================================
# 用法：复制本文件为 .env，填入真实密钥。.env 已在 .gitignore，不会提交。
#   cp env_template.env .env
# 注意：本模板只放占位符，切勿在此填入真实 key。

# MiniMax API（推荐，免费）
MINIMAX_API_KEY=<your_minimax_api_key>

# ====================================
# 豆包 API（可选）
# ====================================
DOUBAO_API_KEY=<your_doubao_api_key>

# ====================================
# 生活教练免密跳转 / 公网地址（公开 8503 时必填）
# ====================================
# 主应用→生活教练签名密钥，生成：openssl rand -hex 32
COACH_SSO_SECRET=<run: openssl rand -hex 32>
# 公网部署改成 http://<服务器IP>:8503，本地可留空（默认 localhost）
LIFE_COACH_URL=http://localhost:8503

# ====================================
# 默认模型配置
# ====================================
# 在 config.py 中设置 DEFAULT_MODEL
# 默认使用 "minimax"
