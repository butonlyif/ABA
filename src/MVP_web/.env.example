# ====================================
# ABA智能助手 - 环境变量配置
# ====================================

# 请复制此文件为 .env 并填入你的API密钥
# 复制命令：cp .env.example .env

# ====================================
# 部署到公网时的每日总调用上限（防 API Key 被刷爆）
# ====================================
# 全站每天最多调用 LLM 的次数；超过后所有用户会看到"今日已达上限"提示。
# 本地单机使用可不设或设很大；公网部署建议根据预算设置。
DAILY_API_LIMIT=500

# ====================================
# 生活教练模块（life_coach，端口 8503）
# ====================================
# 公网用户浏览器加载主应用里的生活教练 iframe 时使用的地址。
# 必须是「服务器的公网地址」，不能是 localhost。例：
# LIFE_COACH_URL=http://170.106.143.145:8503
# 绑了域名+HTTPS 后改成 https://your.domain/coach 之类。
LIFE_COACH_URL=http://localhost:8503

# 主应用→生活教练免密跳转的签名密钥（防止凭用户名冒充登录）。
# 必须设成一长串随机字符；公开 8503 时这一项是安全的关键。
# 不设的话，生活教练将禁用自动登录、要求用户在 8503 自己输账号密码。
# 生成示例：python -c "import secrets;print(secrets.token_hex(32))"
COACH_SSO_SECRET=

# ====================================
# MiniMax API（推荐，免费额度）
# ====================================
# 获取地址：https://platform.minimaxi.com
MINIMAX_API_KEY=your_minimax_api_key_here

# ====================================
# 语义检索 Embedding 配置
# ====================================
# 默认会优先使用 EMBEDDING_API_KEY；不填时会尝试复用 OPENAI_API_KEY。
# 如果你的模型服务支持 OpenAI-compatible embeddings，请填写对应 base_url 和模型名。
# OpenAI 示例：
# EMBEDDING_API_KEY=sk-your_openai_api_key_here
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
#
# 如果供应商暂不支持 embeddings，可以先关闭大模型重排以减少调用：
# ENABLE_LLM_RERANK=true

# ====================================
# OpenAI API（可选）
# ====================================
# 获取地址：https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_openai_api_key_here

# ====================================
# Claude API（可选）
# ====================================
# 获取地址：https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# ====================================
# 配置说明
# ====================================

# MiniMax（推荐）：
# - 国内可用，无需翻墙
# - 注册送免费额度
# - 访问 https://platform.minimaxi.com 注册

# OpenAI：
# - 需要付费（按token计费）
# - GPT-4o Mini便宜快速
# - 访问 https://platform.openai.com 注册

# Claude：
# - 需要付费
# - 安全性好
# - 访问 https://console.anthropic.com 注册

# ====================================
# 如何获取MiniMax API密钥
# ====================================

# 1. 访问 MiniMax 开放平台：https://platform.minimaxi.com
# 2. 注册/登录账号
# 3. 进入「个人设置」→「接口密钥」
# 4. 创建新的密钥或使用已有密钥
# 5. 将密钥粘贴到上方 MINIMAX_API_KEY= 后面
