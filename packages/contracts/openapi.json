            "format": "date-time",
            "title": "Submitted At"
          },
          "generated_task_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Generated Task Ids",
            "default": []
          }
        },
        "type": "object",
        "required": [
          "id",
          "child_id",
          "score",
          "stage",
          "submitted_at"
        ],
        "title": "AssessmentOut"
      },
      "AssessmentSubmit": {
        "properties": {
          "child_id": {
            "type": "string",
            "title": "Child Id"
          },
          "answers": {
            "additionalProperties": {
              "type": "integer"
            },
            "type": "object",
            "title": "Answers"
          }
        },
        "type": "object",
        "required": [
          "child_id",
          "answers"
        ],
        "title": "AssessmentSubmit"
      },
      "ChatRequest": {
        "properties": {
          "message": {
            "type": "string",
            "maxLength": 4000,
            "minLength": 1,
            "title": "Message"
          },
          "child_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Child Id"
          }
        },
        "type": "object",
        "required": [
          "message"
        ],
        "title": "ChatRequest"
      },
      "ChildIn": {
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 80,
            "minLength": 1,
            "title": "Name"
          },
          "birth_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "Birth Date"
          },
          "diagnosis": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Diagnosis"
          },
          "goals": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Goals"
          }
        },
        "type": "object",
        "required": [
          "name"
        ],
        "title": "ChildIn"
      },
      "ChildOut": {
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 80,
            "minLength": 1,
            "title": "Name"
          },
          "birth_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
